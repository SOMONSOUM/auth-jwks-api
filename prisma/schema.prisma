generator client {
  provider     = "prisma-client"
  output       = "../src/generated/prisma"
  moduleFormat = "cjs"
}

datasource db {
  provider = "mysql"
}

model User {
  id        Int      @id @default(autoincrement())
  email     String   @unique @map("email")
  password  String   @map("password")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  refreshTokens RefreshToken[]

  @@map("users")
}

model RefreshToken {
  id        Int      @id @default(autoincrement())
  userId    Int      @map("user_id")
  token     String   @map("token")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")
  revokedAt DateTime @map("revoked_at")
  revoked   Boolean  @default(false) @map("revoked")
  jwkId     Int?     @map("jwk_id")

  user User @relation(fields: [userId], references: [id])
  jwk  Jwk? @relation(fields: [jwkId], references: [id])

  @@unique([userId, token])
  @@map("refresh_tokens")
}

model Jwk {
  id        Int       @id @default(autoincrement())
  kid       String    @unique @map("kid")
  publicKey Json      @map("public_key")
  algorithm String    @map("algorithm")
  status    KeyStatus @map("status")
  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")

  // Relationship JWK to Refresh Token
  refreshTokens RefreshToken[]

  @@map("jwks")
}

enum KeyStatus {
  ACTIVE
  INACTIVE
}
